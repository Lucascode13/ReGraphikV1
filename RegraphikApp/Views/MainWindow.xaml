<Window x:Class="RegraphikApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RegraphikApp.ViewModels"
        Title="ReGraphik" Height="400" Width="500">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <StackPanel>
            <TextBox Margin="0,5"
                     Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>

            <PasswordBox x:Name="SenhaBox" Margin="0,5"/>

            <Button Content="Entrar"
                    Click="ButtonEntrar_Click"/>
        </StackPanel>
    </Grid>
</Window>
